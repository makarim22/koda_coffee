rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // User Profile Validation
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'name', 'createdAt']) &&
        data.keys().size() >= 3 &&
        data.keys().size() <= 4 &&
        data.userId is string && data.userId.size() <= 128 &&
        data.name is string && data.name.size() <= 100 &&
        data.createdAt is number &&
        (
          !('email' in data.keys()) ||
          (data.email is string && data.email.size() <= 200)
        ) &&
        data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;

      allow create: if isSignedIn() &&
        isValidId(userId) &&
        request.auth.uid == userId &&
        isValidUserProfile(incoming());

      allow update: if isSignedIn() &&
        isValidId(userId) &&
        request.auth.uid == userId &&
        isValidUserProfile(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name']) &&
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt;
    }
  }
}
